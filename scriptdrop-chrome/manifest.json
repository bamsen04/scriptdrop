{
    "manifest_version": 3,
    "name": "ScriptDrop",
    "version": "1.0.0",
    "description": "Injects module script on configured URLs",
    "permissions": ["scripting", "tabs"],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    }
}
